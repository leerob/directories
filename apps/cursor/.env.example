NEXT_PUBLIC_SUPABASE_URL=<your_supabase_project_url>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your_supabase_anon_key>
SUPABASE_SERVICE_ROLE_KEY=

RESEND_API_KEY=<your_resend_api_key>

NEXT_PUBLIC_APP_URL=http://localhost:3000

MCP_OWNER_ID=

ADMIN_USER_IDS=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Plugin auto-review pipeline
CURSOR_API_KEY=
# Empty scratch repo the cloud review agent runs in. The agent never reads it;
# it only exists to satisfy CloudOptions.repos being non-empty.
CURSOR_REVIEW_WORKSPACE_REPO=https://github.com/your-org/plugin-review-workspace
# Used by Vercel Cron to authenticate /api/cron/scan-plugins/* routes.
CRON_SECRET=
# Optional tuning.
PLUGIN_SCAN_BATCH_SIZE=5
